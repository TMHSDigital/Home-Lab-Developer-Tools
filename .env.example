# Raspberry Pi SSH connection
HOMELAB_PI_HOST=raspi5.local
HOMELAB_PI_USER=tmhs
HOMELAB_PI_KEY_PATH=~/.ssh/id_ed25519_pi

# Compose project directory on the Pi
HOMELAB_COMPOSE_DIR=/opt/homelab/docker

# Backup repo path on the Pi
HOMELAB_BACKUP_REPO=/mnt/backup/restic

# Grafana authentication (pick one method)
# Option 1: API token (preferred)
# HOMELAB_GRAFANA_TOKEN=glsa_xxxxxxxxxxxx
# Option 2: Basic auth (defaults to admin/admin if neither is set)
# HOMELAB_GRAFANA_USER=admin
# HOMELAB_GRAFANA_PASSWORD=your-password

# AdGuard Home authentication (defaults to admin/admin)
# HOMELAB_ADGUARD_USER=admin
# HOMELAB_ADGUARD_PASSWORD=your-password

# Nginx Proxy Manager authentication (defaults to admin@example.com/changeme)
# HOMELAB_NPM_EMAIL=admin@example.com
# HOMELAB_NPM_PASSWORD=your-password

# Service port overrides (defaults shown -- only set if you remap ports)
# HOMELAB_PROMETHEUS_PORT=9090
# HOMELAB_GRAFANA_PORT=3000
# HOMELAB_ALERTMANAGER_PORT=9093
# HOMELAB_UPTIME_KUMA_PORT=3001
# HOMELAB_SPEEDTEST_PORT=8765
# HOMELAB_ADGUARD_PORT=3000
# HOMELAB_NPM_PORT=81
# HOMELAB_NTFY_PORT=8080
